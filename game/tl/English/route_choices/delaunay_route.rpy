    delaunay "Hell no! A moustache, darling! I do have a bit of taste..."

# game/route_choices/delaunay_route.rpy:1499
translate English del_4_3_86b6c67f:

    # peacock "Tu as quelque chose contre les barbes ma belle ?"
    peacock "Have you got something against beards, love?"

# game/route_choices/delaunay_route.rpy:1505
translate English del_4_3_da597401:

    # delaunay "Non ! Du tout ! La tienne te sied très bien... Malgré les trous~"
    delaunay "No! Not at all! Yours suits you very well... Despite the holes~"

# game/route_choices/delaunay_route.rpy:1510
translate English del_4_3_fbfcb3cf:

    # peacock "Hm... C'est vrai que la testo ne t'a pas trop épargné là-dessus... Une absence de barbe, des poils aux fesses et un début de calvitie..."
    peacock "Hm... It's true that the hormones didn't spare you too much on that score... No beard, hairy buttocks and nascent baldness..."

# game/route_choices/delaunay_route.rpy:1517
