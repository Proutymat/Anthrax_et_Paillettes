# game/route_choices/delaunay_route.rpy:1102
translate English del_4_9036d2c8:

    # text "Évidemment, tout le monde chit-chattait gaîment, mais je ne pus m'empêcher de fixer un instant Léandre."
    text "Of course, everyone was chitter-chattering happily, but I couldn't help staring at Léandre for a moment."

