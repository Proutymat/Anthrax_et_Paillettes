# game/route_choices/delaunay_route.rpy:1201
translate English del_4_1_18d700b0:

    # delaunay "Alors Delaunay l'est à ma place, et m'aide à explorer cette facette de ma personne que je cherche à redécouvrir."
    delaunay "So Delaunay does it for me, and helps me to explore this facet of myself that I'm trying to rediscover."

# game/route_choices/delaunay_route.rpy:1203
translate English del_4_1_9028bc08:

