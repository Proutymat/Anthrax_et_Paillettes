    delaunay "I did backtrack quite a bit on the hypermasculinisation when my body started to change."

# game/route_choices/delaunay_route.rpy:1549
translate English del_4_3_6c7b6d41:

    # delaunay "Je me suis réconcilié avec moi-même, et donc Delaunay n'avait plus besoin de servir cette fonction."
    delaunay "I reconciled with myself, so Delaunay no longer needed to serve this function."

# game/route_choices/delaunay_route.rpy:1551
